# Copy this file to .env before running Docker Compose.
# Do not commit real secrets.

# Required before saving API keys.
# Generate with:
# backend/.venv/Scripts/python.exe -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# or in Docker/Linux:
# docker run --rm python:3.13-slim sh -c "pip install cryptography==49.0.0 >/dev/null && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
RAG_TENDER_SECRET_KEY=replace-with-your-generated-fernet-key

# Host port exposed by the frontend container.
# Use 8088 by default to avoid conflicts with existing Nginx/Apache/BT panel on port 80.
RAG_TENDER_HTTP_PORT=8088

# Docker/Linux default. Windows local runs can keep the app default path.
LIBREOFFICE_PATH=/usr/bin/soffice

# Optional. Comma-separated browser origins allowed to call the backend directly.
# When using the bundled Nginx frontend container, requests are same-origin via /api.
RAG_TENDER_CORS_ORIGINS=http://localhost,http://127.0.0.1
